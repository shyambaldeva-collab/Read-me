<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Literata:ital,wght@0,400;0,600;0,700;1,400&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed": "#f4dfcb",
                        "inverse-primary": "#c8c6c5",
                        "on-tertiary": "#ffffff",
                        "tertiary-container": "#241a0d",
                        "on-primary": "#ffffff",
                        "primary-fixed": "#e5e2e1",
                        "inverse-on-surface": "#f2f1ec",
                        "surface-bright": "#fbf9f4",
                        "error": "#ba1a1a",
                        "secondary-fixed": "#e8e2d6",
                        "on-secondary": "#ffffff",
                        "on-secondary-fixed-variant": "#4a473e",
                        "surface": "#fbf9f4",
                        "surface-container-highest": "#e4e2dd",
                        "tertiary-fixed-dim": "#d7c3b0",
                        "on-secondary-fixed": "#1e1c14",
                        "on-background": "#1b1c19",
                        "on-tertiary-fixed": "#241a0d",
                        "surface-container-high": "#eae8e3",
                        "error-container": "#ffdad6",
                        "inverse-surface": "#30312e",
                        "primary-container": "#1c1b1b",
                        "background": "#fbf9f4",
                        "outline": "#747878",
                        "surface-container": "#f0eee9",
                        "on-surface-variant": "#444748",
                        "surface-container-low": "#f5f3ee",
                        "surface-container-lowest": "#ffffff",
                        "tertiary": "#000000",
                        "secondary-fixed-dim": "#cbc6ba",
                        "on-tertiary-fixed-variant": "#524436",
                        "on-surface": "#1b1c19",
                        "on-error-container": "#93000a",
                        "outline-variant": "#c4c7c7",
                        "primary-fixed-dim": "#c8c6c5",
                        "on-secondary-container": "#68645b",
                        "primary": "#000000",
                        "surface-tint": "#5f5e5e",
                        "surface-dim": "#dbdad5",
                        "on-error": "#ffffff",
                        "on-primary-fixed": "#1c1b1b",
                        "secondary": "#625e55",
                        "on-primary-container": "#858383",
                        "secondary-container": "#e8e2d6",
                        "surface-variant": "#e4e2dd",
                        "on-tertiary-container": "#928170",
                        "on-primary-fixed-variant": "#474746"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "margin-desktop": "40px",
                        "container-max": "1140px",
                        "stack-xl": "80px",
                        "stack-lg": "48px",
                        "stack-sm": "12px",
                        "stack-xs": "4px",
                        "gutter": "24px",
                        "unit": "8px",
                        "stack-md": "24px",
                        "margin-mobile": "20px"
                    },
                    "fontFamily": {
                        "label-sm": ["Inter"],
                        "body-lg": ["Literata"],
                        "headline-md": ["Literata"],
                        "label-lg": ["Inter"],
                        "headline-lg-mobile": ["Literata"],
                        "headline-lg": ["Literata"],
                        "label-md": ["Inter"],
                        "display-lg": ["Literata"],
                        "body-md": ["Literata"]
                    },
                    "fontSize": {
                        "label-sm": ["11px", {"lineHeight": "14px", "letterSpacing": "0.03em", "fontWeight": "400"}],
                        "body-lg": ["20px", {"lineHeight": "32px", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "label-lg": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "600"}],
                        "headline-lg-mobile": ["28px", {"lineHeight": "36px", "fontWeight": "600"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "label-md": ["12px", {"lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "500"}],
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "body-md": ["16px", {"lineHeight": "26px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            background-color: #fbf9f4;
            color: #1b1c19;
            -webkit-font-smoothing: antialiased;
        }
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 24px;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="font-body-md text-body-md min-h-screen pb-24">
<!-- Top App Bar -->
<header class="fixed top-0 w-full z-50 bg-background dark:bg-background flex items-center justify-between px-margin-mobile h-16 transition-all duration-250 ease-in-out">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-secondary-container flex items-center justify-center overflow-hidden">
<img alt="Profile" class="w-full h-full object-cover" data-alt="A close-up, high-quality professional portrait of a woman with a serene expression, set against a soft-focus library background. The lighting is natural and warm, reflecting a sophisticated and intellectual brand identity. The color palette is muted and editorial, consistent with a premium reading application interface." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBwAzHogSVcea8KNqHH2dSxtNyTwHVGJ9D1t2z-v04xQxiRipn99jHPwcSf1hFevEIMF1t9LYTkFRrp7_gfOT8nFQqWbaVBkJu7NJjuwMvvPcPp2Adr3G5UfViGX6sVB3Y0NZNXoauFsgIBziS5q0jQ2ynd5PMu3aFQzQTV3cZ2fbQZ98N0jNklD7pbQ5rDMvCMCLcEQR9HZtXRSHCUZK_47y03MbPEOx6tEYzNz4XBqEddHy8OIc7YKkvU-QxsEbEWyC5Jzf-w1w"/>
</div>
<span class="font-headline-md text-headline-md font-semibold text-primary dark:text-on-background">ReadFlow</span>
</div>
<button class="material-symbols-outlined text-primary dark:text-on-background hover:opacity-80 transition-opacity" data-icon="search">search</button>
</header>
<main class="max-w-[1140px] mx-auto px-margin-mobile mt-20">
<!-- Hero: Your Reading Journey -->
<section class="mb-stack-lg">
<h1 class="font-headline-lg text-headline-lg mb-stack-md">Your Reading Journey</h1>
<div class="bg-surface-container-low rounded-xl p-8 flex flex-col md:flex-row items-center justify-between border border-outline-variant/30">
<div class="flex flex-col gap-2 mb-6 md:mb-0">
<span class="font-label-lg text-label-lg text-on-surface-variant">CURRENT STREAK</span>
<div class="flex items-baseline gap-2">
<span class="text-display-lg font-display-lg">7</span>
<span class="font-headline-md text-headline-md text-secondary">days</span>
</div>
<p class="text-on-surface-variant font-body-md italic">You're in the top 5% of readers this week.</p>
</div>
<div class="flex gap-3 md:gap-4">
<!-- Streak Visual -->
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">M</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">T</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">W</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">T</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">F</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-lg">S</div>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="flex flex-col items-center gap-2">
<div class="w-10 h-10 rounded-full bg-secondary-container text-primary flex items-center justify-center font-label-lg border-2 border-primary">S</div>
<span class="material-symbols-outlined text-primary">circle</span>
</div>
</div>
</div>
</section>
<!-- Bento Stats Layout -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter mb-stack-lg">
<!-- Weekly Activity Bar Chart -->
<div class="md:col-span-8 bg-surface-container rounded-xl p-6 border border-outline-variant/20">
<div class="flex justify-between items-center mb-8">
<h2 class="font-headline-md text-headline-md">Weekly Activity</h2>
<span class="font-label-md text-label-md bg-secondary-fixed px-3 py-1 rounded-full text-on-secondary-fixed-variant">Minutes Read</span>
</div>
<div class="flex items-end justify-between h-48 gap-2 md:px-4">
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 60%;"></div>
<span class="font-label-sm text-label-sm">Mon</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 45%;"></div>
<span class="font-label-sm text-label-sm">Tue</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 85%;"></div>
<span class="font-label-sm text-label-sm">Wed</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 30%;"></div>
<span class="font-label-sm text-label-sm">Thu</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 70%;"></div>
<span class="font-label-sm text-label-sm">Fri</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary/10 rounded-t-lg transition-all" style="height: 95%;"></div>
<span class="font-label-sm text-label-sm">Sat</span>
</div>
<div class="flex-1 flex flex-col items-center gap-2">
<div class="w-full bg-primary rounded-t-lg transition-all" style="height: 25%;"></div>
<span class="font-label-sm text-label-sm font-bold">Sun</span>
</div>
</div>
</div>
<!-- Daily Goal Progress Ring -->
<div class="md:col-span-4 bg-tertiary-fixed/30 rounded-xl p-6 flex flex-col items-center justify-center border border-tertiary-fixed text-center">
<h2 class="font-label-lg text-label-lg mb-6 text-on-tertiary-fixed-variant">DAILY GOAL</h2>
<div class="relative w-40 h-40 flex items-center justify-center mb-4">
<svg class="w-full h-full transform -rotate-90">
<circle class="text-tertiary-fixed-dim" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-width="8"></circle>
<circle class="text-primary" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-dasharray="440" stroke-dashoffset="146.6" stroke-width="8"></circle>
</svg>
<div class="absolute flex flex-col items-center">
<span class="font-display-lg text-[32px] leading-tight">20</span>
<span class="font-label-md text-label-md opacity-70">/ 30 min</span>
</div>
</div>
<p class="font-body-md text-on-tertiary-fixed">10 more minutes to goal!</p>
</div>
</div>
<!-- Secondary Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-stack-lg">
<div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20">
<span class="material-symbols-outlined text-secondary mb-2" data-icon="book">book</span>
<p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Total Books Read</p>
<p class="font-headline-lg text-headline-lg mt-1">14</p>
</div>
<div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20">
<span class="material-symbols-outlined text-secondary mb-2" data-icon="history_edu">history_edu</span>
<p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Total Highlights</p>
<p class="font-headline-lg text-headline-lg mt-1">342</p>
</div>
<div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20">
<span class="material-symbols-outlined text-secondary mb-2" data-icon="speed">speed</span>
<p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Avg. Reading Speed</p>
<p class="font-headline-lg text-headline-lg mt-1">285 <span class="text-body-md font-normal">wpm</span></p>
</div>
</div>
<!-- Achievements Section -->
<section class="mb-stack-xl">
<div class="flex justify-between items-end mb-6">
<div>
<h2 class="font-headline-md text-headline-md">Achievements</h2>
<p class="text-on-surface-variant font-body-md">Your milestones and reading legacy.</p>
</div>
<button class="text-primary font-label-lg hover:underline transition-all">View All</button>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-gutter">
<!-- Badge Unlocked -->
<div class="flex flex-col items-center p-6 bg-surface-container rounded-xl border border-primary/10">
<div class="w-16 h-16 rounded-full bg-tertiary-fixed flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="light_mode" style="font-variation-settings: 'FILL' 1;">light_mode</span>
</div>
<h3 class="font-label-lg text-label-lg mb-1">Early Bird</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant text-center">Read for 5 days before 8 AM</p>
</div>
<!-- Badge Unlocked -->
<div class="flex flex-col items-center p-6 bg-surface-container rounded-xl border border-primary/10">
<div class="w-16 h-16 rounded-full bg-secondary-fixed flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="weekend" style="font-variation-settings: 'FILL' 1;">weekend</span>
</div>
<h3 class="font-label-lg text-label-lg mb-1">Weekend Warrior</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant text-center">2+ hours on Sat &amp; Sun</p>
</div>
<!-- Badge Locked -->
<div class="flex flex-col items-center p-6 bg-surface-variant/30 rounded-xl border border-outline-variant grayscale opacity-60">
<div class="w-16 h-16 rounded-full bg-surface-container-highest flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-on-surface-variant text-3xl" data-icon="water_drop">water_drop</span>
</div>
<h3 class="font-label-lg text-label-lg mb-1">Deep Diver</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant text-center">Complete a 400+ page book</p>
</div>
<!-- Badge Locked -->
<div class="flex flex-col items-center p-6 bg-surface-variant/30 rounded-xl border border-outline-variant grayscale opacity-60">
<div class="w-16 h-16 rounded-full bg-surface-container-highest flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-on-surface-variant text-3xl" data-icon="auto_stories">auto_stories</span>
</div>
<h3 class="font-label-lg text-label-lg mb-1">Bibliophile</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant text-center">Read 50 books in a year</p>
</div>
</div>
</section>
</main>
<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 w-full z-50 bg-surface-container dark:bg-surface-container border-t border-outline-variant dark:border-outline-variant flex justify-around items-center h-16 px-4">
<a class="flex flex-col items-center justify-center text-on-surface-variant dark:text-on-surface-variant hover:bg-surface-variant dark:hover:bg-surface-variant transition-transform duration-200 scale-95" href="#">
<span class="material-symbols-outlined" data-icon="local_library">local_library</span>
<span class="font-label-md text-label-md">Library</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant dark:text-on-surface-variant hover:bg-surface-variant dark:hover:bg-surface-variant transition-transform duration-200 scale-95" href="#">
<span class="material-symbols-outlined" data-icon="explore">explore</span>
<span class="font-label-md text-label-md">Discovery</span>
</a>
<a class="flex flex-col items-center justify-center text-primary dark:text-on-background font-semibold hover:bg-surface-variant dark:hover:bg-surface-variant transition-transform duration-200 scale-95" href="#">
<span class="material-symbols-outlined" data-icon="analytics" style="font-variation-settings: 'FILL' 1;">analytics</span>
<span class="font-label-md text-label-md">Analytics</span>
</a>
</nav>
<!-- Reading Progress Bar (System Component) -->
<div class="fixed bottom-16 left-0 w-full h-[2px] bg-secondary-fixed/50">
<div class="h-full bg-primary" style="width: 66%;"></div>
</div>
</body></html>